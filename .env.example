# Self-Wiki — Composer-first (copy to .env)

# Default provider for sync / compress / wiki (when no role override)
LLM_PROVIDER=mlx
# LLM_URL=http://127.0.0.1:8080/v1/chat/completions
# LLM_MODEL=mlx-community/Qwen3-4B-Instruct-2507-4bit

# Role-specific providers (optional; override LLM_PROVIDER per pipeline stage)
# AGENT_LLM_PROVIDER=gemini       # discover / gap / evolution (make reflect)
# QUERY_LLM_PROVIDER=gemini
# LINT_LLM_PROVIDER=gemini
# COMPRESS_LLM_PROVIDER=mlx
# WIKI_LLM_PROVIDER=gemini

# Cloud API (set LLM_PROVIDER=gemini or openai + API key)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash-lite

# Agent roles (discover/gap/evolution) default to gemini when GEMINI_API_KEY is set.
# MLX is last-resort fallback when LLM_MLX_LAST_RESORT=1 (default on).

# Last-resort MLX when cloud fails or has no API key (default on):
# LLM_MLX_LAST_RESORT=1

# Python batch compress/discover (default: Composer writes files in Cursor)
# ALLOW_PYTHON_LLM=1
# POSTS_BATCH=1
# MAX_INGEST_BATCH_TOKENS=150000
# MAX_INGEST_BATCH_FILES=8
# POSTS_BATCH_MAX_LINES=400
# INGEST_OUTPUT_PER_FILE=2500

# OpenAI-compatible cloud (alternative to gemini)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# LLM_PROVIDER=openai

# Fallback (cloud first for agents/query; MLX appended last when LLM_MLX_LAST_RESORT=1)
# AGENT_FALLBACK_PROVIDERS=mlx
# QUERY_FALLBACK_PROVIDERS=mlx
# LLM_FALLBACK_PROVIDERS=gemini
# LLM_FALLBACK_ENABLED=1

# Rate limiting for batch compress (avoid Gemini 429)
# GEMINI_RETRY_ATTEMPTS=4
# GEMINI_RETRY_BACKOFF_SECONDS=20
# INGEST_REQUEST_DELAY_SECONDS=2
# MAX_CONTEXT_TOKENS=1000000
# RESERVED_OUTPUT_TOKENS=16384

# WORKSPACE_PATH=/path/to/dev.self-wiki
# QUERY_WEB_HOST=127.0.0.1
# QUERY_WEB_PORT=5050

# Theme incubation (make incubate-themes) — cross-file new L1 thresholds
# INCUBATE_SUPPORT_COUNT=3
# INCUBATE_MEAN_CONF=0.78
# INCUBATE_MAX_CONF=0.82
# INCUBATE_MIN_FILE_CONF=0.75
