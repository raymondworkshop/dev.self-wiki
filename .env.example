# Self-Wiki — Composer-first (copy to .env)

# Cloud API for make query / make audit LINT=1 (local MLX disabled by default)
QUERY_LLM_PROVIDER=gemini
LINT_LLM_PROVIDER=gemini
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash-lite

# Do NOT use local MLX as primary unless you explicitly opt in:
# ALLOW_LOCAL_LLM=1
# LLM_PROVIDER=mlx
# LLM_URL=http://127.0.0.1:8080/v1/chat/completions
# LLM_MODEL=mlx-community/gemma-4-e4b-it-4bit

# Last-resort MLX when cloud fails or has no API key (default on):
# LLM_MLX_LAST_RESORT=1

# Python batch compress/discover (default: Composer writes files in Cursor)
# ALLOW_PYTHON_LLM=1
# INGEST_LLM_PROVIDER=gemini

# OpenAI-compatible cloud (alternative to gemini)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# QUERY_LLM_PROVIDER=openai

# Fallback (cloud first; MLX appended last when LLM_MLX_LAST_RESORT=1)
# QUERY_FALLBACK_PROVIDERS=openai
# LLM_FALLBACK_PROVIDERS=openai
# LLM_FALLBACK_ENABLED=1

# Rate limiting for batch compress (avoid Gemini 429)
# GEMINI_RETRY_ATTEMPTS=4
# GEMINI_RETRY_BACKOFF_SECONDS=20
# INGEST_REQUEST_DELAY_SECONDS=2
# MAX_CONTEXT_TOKENS=1000000
# RESERVED_OUTPUT_TOKENS=16384

# WORKSPACE_PATH=/path/to/dev.self-wiki
# QUERY_WEB_HOST=127.0.0.1
# QUERY_WEB_PORT=5050
