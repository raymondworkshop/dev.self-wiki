# Self-Wiki LLM configuration (copy to .env and fill secrets)
# Default provider for make sync / run-skill
LLM_PROVIDER=mlx

# Local MLX / OpenAI-compatible endpoint
LLM_URL=http://127.0.0.1:8080/v1/chat/completions
LLM_MODEL=mlx-community/gemma-4-e4b-it-4bit

# Gemini (cloud)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-pro

# OpenAI-compatible cloud (LLM_PROVIDER=openai)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# LLM_URL=https://api.openai.com/v1/chat/completions

# Token budgets (optional)
# MAX_CONTEXT_TOKENS=8092
# RESERVED_OUTPUT_TOKENS=1200
# PROMPT_SAFETY_MARGIN=500

# Repo root (optional; auto-detected if omitted)
# WORKSPACE_PATH=/path/to/dev.self-wiki

# Read-only query site (same pipeline as make query)
# QUERY_WEB_HOST=127.0.0.1
# QUERY_WEB_PORT=5050
# QUERY_WEB_HOST=0.0.0.0   # Tailscale / LAN
