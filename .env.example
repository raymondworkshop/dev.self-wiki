# Self-Wiki LLM configuration (copy to .env and fill secrets)
# Default provider for make sync
LLM_PROVIDER=mlx
# Cloud provider for make query / make query-web / make audit LINT=1
# QUERY_LLM_PROVIDER=gemini
# LINT_LLM_PROVIDER=gemini

# Local MLX / OpenAI-compatible endpoint
LLM_URL=http://127.0.0.1:8080/v1/chat/completions
LLM_MODEL=mlx-community/gemma-4-e4b-it-4bit

# Gemini (cloud)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash-lite

# OpenAI-compatible cloud (LLM_PROVIDER=openai)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# LLM_URL=https://api.openai.com/v1/chat/completions

# Token budgets (optional)
# MAX_CONTEXT_TOKENS=8092
# RESERVED_OUTPUT_TOKENS=1200   # mlx default; raise if ingest JSON truncates
# INGEST_MAX_OUTPUT_TOKENS=2048
# INGEST_MAX_OUTPUT_TOKENS_CAP=4096
# INGEST_PARSE_RETRY_ATTEMPTS=2

# Fallback chains (default: on via LLM_FALLBACK_ENABLED=1)
# Sync (make sync): LLM_PROVIDER first, then LLM_FALLBACK_PROVIDERS
# LLM_FALLBACK_PROVIDERS=gemini
# Query / lint: QUERY_LLM_PROVIDER first, then QUERY_FALLBACK_PROVIDERS
# QUERY_FALLBACK_PROVIDERS=mlx
# LINT_FALLBACK_PROVIDERS=mlx
# PROMPT_SAFETY_MARGIN=500

# Repo root (optional; auto-detected if omitted)
# WORKSPACE_PATH=/path/to/dev.self-wiki

# Read-only query site (same pipeline as make query)
# QUERY_WEB_HOST=127.0.0.1
# QUERY_WEB_PORT=5050
# QUERY_WEB_HOST=0.0.0.0   # Tailscale / LAN
